# Use your own model and key — there's nothing to request from us.
# Copy this file to .env and set your own provider, key, and models.
# Defaults assume an OpenAI-compatible API; adjust for Azure, Anthropic, or a local model.
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your-own-key-here
LLM_EMBED_MODEL=text-embedding-3-small
LLM_CHAT_MODEL=gpt-4o-mini
